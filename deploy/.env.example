# Linen Draper - Production Environment Variables
# Copy this file to /etc/linen-draper/env and fill in your SMTP credentials.

# Environment mode (must be "production" for email sending)
APP_ENV=production
LINEN_DRAPER_ENV=production

# SMTP Configuration
# Use your email provider's SMTP settings.
# For Gmail: smtp.gmail.com, port 587, use an App Password.
# For SendGrid: smtp.sendgrid.net, port 587, use an API key.
# For self-hosted: your SMTP server address.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# Public URL (used by frontend JavaScript to reach the backend)
# Must match the domain configured in Caddy.
# Example: https://app.example.com
API_URL=https://linen-draper.example.com
